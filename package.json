{
  "name": "fn-data-api-bakeoff-codex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"npm run dev -w @island-intel/api\" \"npm run dev -w @island-intel/web\"",
    "dev:api": "npm run dev -w @island-intel/api",
    "dev:web": "npm run dev -w @island-intel/web",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "test": "npm test --workspaces",
    "ingest": "npm run ingest -w @island-intel/api --"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
