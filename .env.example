# Local defaults
PORT=3201
CORS_ORIGIN=http://localhost:3200
VITE_API_BASE_URL=http://localhost:3201

# Backend persistence
DB_PATH=./data/islands.db

# Optional ingestion behavior on API start
INGEST_ON_START=false
INGEST_METADATA_LIMIT=1000
INGEST_METRICS_LIMIT=25
INGEST_INTERVAL_MINUTES=30
METADATA_CRAWL_INTERVAL_MINUTES=360
